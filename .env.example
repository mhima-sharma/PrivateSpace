AUTH_TRUST_HOST="true"


WEBAUTHN_RP_ID="localhost"
WEBAUTHN_RP_NAME="PrivateSpace"
WEBAUTHN_RP_ORIGIN="http://localhost:3000"
STORAGE_DRIVER="local"
IMAGE_URL_SIGNING_SECRET="Iq75T7ZgRiX9YkeuH0zFxhf02penrExdJyu9HkZGSHFle1t9AQbfnl4vaejU/WyQ"
