MAX_UPLOAD_BYTES="8388608"

# ── Cloudinary (only when STORAGE_DRIVER="cloudinary") ────────────────────
# Uploaded as delivery type "authenticated" (private). The app never exposes
# Cloudinary URLs — it fetches bytes server-side via a signed URL and streams
# them through our own signed /api/images/[id] route.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── S3-compatible storage (only when STORAGE_DRIVER=s3) ───────────────────
# Works with AWS S3, Cloudflare R2, Backblaze B2, MinIO, etc.
# The bucket MUST be PRIVATE (no public ACLs). We never expose object URLs;
# clients only ever receive our own signed /api/images/[id] URLs.
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET="privatespace-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Force path-style addressing (needed for R2/MinIO).
S3_FORCE_PATH_STYLE="true"

# ── Rate limiting ─────────────────────────────────────────────────────────
# In-memory by default (per-instance). For multi-instance prod, point these
# at Upstash Redis (optional — see lib/rate-limit.ts for the interface).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── App config ────────────────────────────────────────────────────────────
# Bootstrap admin: the first user who registers with this email is granted ADMIN.
BOOTSTRAP_ADMIN_EMAIL="dev.nest.ms@gmail.com"
# Invite link lifetime in hours.
INVITE_TTL_HOURS="72"
# Birthday config (drives countdown + hero). ISO date.
NEXT_PUBLIC_BIRTHDAY_DATE="2026-09-12"
