# ─────────────────────────────────────────────────────────────
# TrendTales — Environment Variables
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Database (MySQL / TiDB / PlanetScale — MySQL-compatible)
# Example local: mysql://root:password@localhost:3306/trendtales
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/trendtales"

# NextAuth (Auth.js v5)
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# Base URL of the deployment (no trailing slash). In dev: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Public site URL (used for SEO canonical URLs, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="TrendTales"

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# This one is exposed to the browser for the upload widget
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# Optional: unsigned upload preset name (if using unsigned uploads)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="trendtales_unsigned"

# Seed admin (used by `npm run db:seed`)
SEED_ADMIN_EMAIL="admin@trendtales.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="TrendTales Admin"
