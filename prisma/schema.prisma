// PrivateSpace — Prisma schema for TiDB Serverless (MySQL-compatible).
//
// Notes for TiDB:
//  - TiDB speaks the MySQL protocol; provider = "mysql".
//  - TiDB does not support foreign key constraint enforcement the same way
//    InnoDB does on older versions, and Prisma's `relationMode = "prisma"`
//    keeps referential integrity at the application layer — the safe default
//    for TiDB Serverless. Indexes are declared explicitly because of this.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum Role {
  USER
  ADMIN
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String   @map("password_hash")
  name            String?
  bio             String?  @db.Text
  role            Role     @default(USER)
  webauthnEnabled Boolean  @default(false) @map("webauthn_enabled")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  photos      Photo[]
  likes       Like[]
  comments    Comment[]
  auditLogs   AuditLog[]
  credentials Authenticator[]
  invitesSent Invite[]        @relation("InvitesCreatedBy")
  albums      Album[]         @relation("AlbumsCreatedBy")
  events      Event[]         @relation("EventsCreatedBy")

  @@map("users")
}

model Invite {
  id          String    @id @default(cuid())
  token       String    @unique // store the SHA-256 hash of the raw token, never the raw value
  email       String
  role        Role      @default(USER)
  used        Boolean   @default(false)
  usedAt      DateTime? @map("used_at")
  createdById String?   @map("created_by")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  createdBy User? @relation("InvitesCreatedBy", fields: [createdById], references: [id])

  @@index([email])
  @@index([createdById])
  @@map("invites")
}

model Album {
  id        String   @id @default(cuid())
  title     String
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  author User    @relation("AlbumsCreatedBy", fields: [createdBy], references: [id])
  photos Photo[]

  @@index([createdBy])
  @@map("albums")
}

model Photo {
  id          String   @id @default(cuid())
  albumId     String?  @map("album_id")
  uploadedBy  String   @map("uploaded_by")
  // Opaque storage key (S3 object key or local path). NEVER a public URL.
  storageKey  String   @map("image_url")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  width       Int?
  height      Int?
  caption     String?  @db.Text
  isHidden    Boolean  @default(false) @map("is_hidden") // admin moderation
  createdAt   DateTime @default(now()) @map("created_at")

  album    Album?    @relation(fields: [albumId], references: [id])
  uploader User      @relation(fields: [uploadedBy], references: [id])
  likes    Like[]
  comments Comment[]

  @@index([albumId])
  @@index([uploadedBy])
  @@index([createdAt])
  @@map("photos")
}

model Like {
  id      String   @id @default(cuid())
  photoId String   @map("photo_id")
  userId  String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  photo Photo @relation(fields: [photoId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([photoId, userId]) // one like per user per photo
  @@index([userId])
  @@map("likes")
}

model Comment {
  id      String   @id @default(cuid())
  photoId String   @map("photo_id")
  userId  String   @map("user_id")
  message String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  photo Photo @relation(fields: [photoId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([photoId])
  @@index([userId])
  @@map("comments")
}

// Ephemeral "story"-style events created by an admin. Each event is visible on
// the dashboard for a fixed window (24h) via `expiresAt`; afterwards it drops
// out of the active feed but is retained forever so admins can browse the
// archive ("posted this event on <date>"). An optional image is stored exactly
// like a Photo (private object storage), served through /api/event-images/[id].
model Event {
  id          String   @id @default(cuid())
  title       String
  body        String?  @db.Text
  storageKey  String?  @map("image_url") // opaque storage key; null = text-only
  mimeType    String?  @map("mime_type")
  sizeBytes   Int?     @map("size_bytes")
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")

  author User @relation("EventsCreatedBy", fields: [createdById], references: [id])

  @@index([createdById])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("events")
}

// WebAuthn / passkey credential (per SimpleWebAuthn).
model Authenticator {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  credentialId         String   @unique @map("credential_id") // base64url
  credentialPublicKey  Bytes    @map("credential_public_key")
  counter              BigInt   @default(0)
  credentialDeviceType String   @map("credential_device_type")
  credentialBackedUp   Boolean  @map("credential_backed_up")
  transports           String?  @map("transports") // JSON-encoded array
  createdAt            DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("authenticators")
}

// Short-lived WebAuthn challenge store (registration + authentication).
model WebAuthnChallenge {
  id        String   @id @default(cuid())
  // For registration we key by userId; for login (usernameless) by a session id.
  key       String   @unique
  challenge String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("webauthn_challenges")
}

// Editable key/value app settings (e.g. occasion, note, celebrant, date).
// Admin-editable from the console; the app falls back to config defaults when
// a key is absent.
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  ip         String?
  userAgent  String?  @map("user_agent") @db.Text
  metadata   String?  @db.Text // JSON blob
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
